  - nom: Daraa
    sprite: {fileID: 21300000, guid: 6cfb26ce14e7462459b2b4e549a16a46, type: 3}
    offset: {x: 0, y: 0}
    scale: 0.7
    titre: La Flamme
    pv: 4
    competences:
    - magie
    capacite_speciale: "\xC9liminez tous les monstres de la file ayant 1 point de
      vie restant."
    description: 
    citation: "\xAB Le feu est patient. Elle ne l'est pas. \xBB"
  - nom: Gao
    sprite: {fileID: 0}
    offset: {x: 0, y: 0.5}
    scale: 0.7
    titre: Le Gardien
    pv: 4
    competences:
    - soin
    capacite_speciale: "Retire toutes les blessures d'un h\xE9ros au choix."
    description: 
    citation: "\xAB Tant qu'il respire, personne ne tombe. \xBB"
  - nom: Nawel
    sprite: {fileID: 21300000, guid: a2eddd5dff308674eba4cc52fac9e362, type: 3}
    offset: {x: 0, y: 0.5}
    scale: 0.7
    titre: Le Rempart
    pv: 7
    competences:
    - armure
    capacite_speciale: "Annulez toutes les blessures inflig\xE9es \xE0 ce h\xE9ros
      ce tour."
    description: 
    citation: "\xAB Il encaisse. Encore. Et encore. \xBB"
  - nom: Isonash
    sprite: {fileID: 0}
    offset: {x: 0, y: 0.5}
    scale: 0.7
    titre: La Piste
    pv: 5
    competences:
    - distance
    capacite_speciale: "Joue imm\xE9diatement 2 cartes Action de sa main."
    description: 
    citation: "\xAB On voit la premi\xE8re fl\xE8che. Jamais les suivantes. \xBB"
  - nom: Aslan
    sprite: {fileID: 0}
    offset: {x: 0, y: 0.5}
    scale: 0.7
    titre: Le Porte-Voix
    pv: 5
    competences:
    - diplomatie
    capacite_speciale: "Tous les h\xE9ros peuvent s'\xE9changer autant de cartes
      qu'ils le souhaitent jusqu'\xE0 la fin du tour."
    description: 
    citation: "\xAB Cinq tribus parlent par sa bouche. \xBB"
